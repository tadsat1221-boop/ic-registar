PORT=3000
BASE_URL=http://localhost:3000

# このPCではNorton AntivirusのHTTPS検査により証明書検証エラーが出るため、
# Node専用に Norton のルート証明書を追加で信頼させる(該当しない環境では未設定でよい)
NODE_EXTRA_CA_CERTS=./.certs/norton-root.pem

# Resend (https://resend.com) のAPIキー。確認メールの送信に使用します。
# RESEND_FROM_EMAIL は、ドメイン認証していない場合は onboarding@resend.dev のままで構いません。
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev

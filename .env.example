PORT=3000
BASE_URL=http://localhost:3000

# このPCではNorton AntivirusのHTTPS検査により証明書検証エラーが出るため、
# Node専用に Norton のルート証明書を追加で信頼させる(該当しない環境では未設定でよい)
NODE_EXTRA_CA_CERTS=./.certs/norton-root.pem

# Gmail SMTP
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=your-16-digit-app-password

SESSION_SECRET=change-this-to-a-random-string
